<?xml version="1.0" encoding="UTF-8"?>
<inboundEndpoint xmlns="http://ws.apache.org/ns/synapse"
                 name="TelemetryMQTTInbound"
                 onError="fault"
                 protocol="mqtt"
                 sequence="TelemetryNormalizationSeq"
                 statistics="enable"
                 suspend="false"
                 trace="enable">
    <parameters>
        <parameter name="sequential">true</parameter>
        <!-- This factory must be defined in deployment.toml -->
        <parameter name="mqtt.connection.factory">mqttConFactory</parameter>

        <!-- Broker connection (Docker Mosquitto on localhost:1883) -->
        <parameter name="mqtt.server.host.name">localhost</parameter>
        <parameter name="mqtt.server.port">1883</parameter>

        <!-- Telemetry topic pattern -->
        <parameter name="mqtt.topic.name">oem/telemetry/+/+</parameter>

        <!-- Inbound messages are JSON -->
        <parameter name="content.type">application/json</parameter>

        <parameter name="mqtt.subscription.qos">0</parameter>
        <parameter name="mqtt.session.clean">false</parameter>
        <parameter name="mqtt.ssl.enable">false</parameter>
        <parameter name="mqtt.reconnection.interval">1000</parameter>
        <parameter name="mqtt.client.id">telemetryInboundClient</parameter>
    </parameters>
</inboundEndpoint>
