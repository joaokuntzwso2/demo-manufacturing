<?xml version="1.0" encoding="UTF-8"?>
<api xmlns="http://ws.apache.org/ns/synapse"
     name="MachineHealthService"
     context="/internal/machine-health">

    <!-- ==========================================================
         1) HTTP telemetry ingestion
         POST /internal/machine-health/telemetry
       ========================================================== -->
    <resource methods="POST" uri-template="/telemetry">
        <inSequence>

            <log level="custom">
                <property name="MachineHealthService"
                          value="HTTP telemetry ingestion"/>
            </log>

            <!-- Normalize HTTP telemetry to canonical model -->
            <payloadFactory media-type="json">
                <format>
{
  "machineId": "$1",
  "plantId": "$2",
  "timestamp": "$3",
  "temp": $4,
  "vibration": $5
}
                </format>
                <args>
                    <arg evaluator="json" expression="$.machine"/>
                    <arg evaluator="json" expression="$.plant"/>
                    <arg evaluator="json" expression="$.ts"/>
                    <arg evaluator="json" expression="$.temperature"/>
                    <arg evaluator="json" expression="$.vibration"/>
                </args>
            </payloadFactory>

            <property name="messageType"
                      value="application/json"
                      scope="axis2"/>

            <!-- Call telemetry store backend -->
            <call>
                <endpoint>
                    <http method="post"
                          uri-template="http://telemetry-store:9100/telemetry">
                        <suspendOnFailure>
                            <initialDuration>-1</initialDuration>
                            <progressionFactor>-1</progressionFactor>
                            <maximumDuration>0</maximumDuration>
                        </suspendOnFailure>
                        <markForSuspension>
                            <retriesBeforeSuspension>0</retriesBeforeSuspension>
                        </markForSuspension>
                    </http>
                </endpoint>
            </call>

            <!-- Ignore backend response; return our own ack -->
            <payloadFactory media-type="json">
                <format>
{
  "status": "accepted",
  "message": "Telemetry received"
}
                </format>
                <args/>
            </payloadFactory>

            <property name="messageType"
                      value="application/json"
                      scope="axis2"/>

            <respond/>
        </inSequence>

        <outSequence/>
        <faultSequence>
            <log level="full"/>
            <drop/>
        </faultSequence>
    </resource>

    <!-- ==========================================================
         2) Latest readings per machine
         GET /internal/machine-health/telemetry/last-readings
       ========================================================== -->
    <resource methods="GET" uri-template="/telemetry/last-readings">
        <inSequence>

            <log level="custom">
                <property name="MachineHealthService"
                          value="GET last telemetry readings (per machine)"/>
            </log>

            <!-- NOTE: backend path is /last-readings (no /telemetry) -->
            <call>
                <endpoint>
                    <http method="get"
                          uri-template="http://telemetry-store:9100/last-readings"/>
                </endpoint>
            </call>

            <property name="messageType"
                      value="application/json"
                      scope="axis2"/>

            <respond/>
        </inSequence>

        <outSequence/>
        <faultSequence>
            <log level="full"/>
            <drop/>
        </faultSequence>
    </resource>

    <!-- ==========================================================
         3) Plant-level summary
         GET /internal/machine-health/summary
       ========================================================== -->
    <resource methods="GET" uri-template="/summary">
        <inSequence>

            <log level="custom">
                <property name="MachineHealthService"
                          value="GET plant health summary"/>
            </log>

            <call>
                <endpoint>
                    <http method="get"
                          uri-template="http://telemetry-store:9100/summary"/>
                </endpoint>
            </call>

            <property name="messageType"
                      value="application/json"
                      scope="axis2"/>

            <respond/>
        </inSequence>

        <outSequence/>
        <faultSequence>
            <log level="full"/>
            <drop/>
        </faultSequence>
    </resource>

</api>
