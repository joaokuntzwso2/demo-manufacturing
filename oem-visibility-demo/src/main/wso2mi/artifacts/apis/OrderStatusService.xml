<?xml version="1.0" encoding="UTF-8"?>
<api xmlns="http://ws.apache.org/ns/synapse"
     name="OrderStatusService"
     context="/internal/orders">

    <resource methods="GET" uri-template="/orders/{id}">
        <inSequence>

            <!-- Extract the {id} path parameter -->
            <property name="orderId"
                      expression="$url:id"
                      scope="default"/>

            <log level="custom">
                <property name="OrderStatusService" value="Invoking ERP backend"/>
                <property name="orderId"
                          expression="get-property('orderId')"/>
            </log>

            <!-- Call ERP backend: http://localhost:9001/erp/orders/{uri.var.id} -->
            <call>
                <endpoint key="ERPServiceEP"/>
            </call>

            <!-- Store ERP JSON body in a property -->
            <enrich>
                <source clone="true" type="body"/>
                <target action="replace"
                        type="property"
                        property="ERP_RESPONSE"/>
            </enrich>

            <log level="custom">
                <property name="OrderStatusService" value="Invoking MES backend"/>
                <property name="orderId"
                          expression="get-property('orderId')"/>
            </log>

            <!-- Call MES backend: http://localhost:9002/mes/orders/{uri.var.id} -->
            <call>
                <endpoint key="MESServiceEP"/>
            </call>

            <!-- Store MES JSON body in a property -->
            <enrich>
                <source clone="true" type="body"/>
                <target action="replace"
                        type="property"
                        property="MES_RESPONSE"/>
            </enrich>

            <!-- Build combined JSON response with raw ERP/MES payloads -->
            <payloadFactory media-type="json">
                <format>
{
  "orderId": "$1",
  "erpRaw": "$2",
  "mesRaw": "$3"
}
                </format>
                <args>
                    <arg evaluator="xml"
                         expression="get-property('orderId')"/>
                    <arg evaluator="xml"
                         expression="get-property('ERP_RESPONSE')"/>
                    <arg evaluator="xml"
                         expression="get-property('MES_RESPONSE')"/>
                </args>
            </payloadFactory>

            <!-- Ensure JSON response -->
            <property name="messageType"
                      value="application/json"
                      scope="axis2"/>

            <respond/>
        </inSequence>

        <outSequence/>
        <faultSequence>
            <log level="full"/>
            <drop/>
        </faultSequence>
    </resource>
</api>
