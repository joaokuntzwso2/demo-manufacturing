# OEM Visibility Agent - Ballerina HTTP service

FROM ballerina/ballerina:2201.12.9

WORKDIR /app

# Copy the entire Ballerina project
COPY . .

# Build once at image build time (downloads from central, compiles, etc.)
RUN bal build

# Expose agent HTTP port
EXPOSE 8293

# Run the compiled artifact to avoid recompiling inside the container
CMD ["bal", "run", "target/bin/oem_visibility_agent.jar"]
